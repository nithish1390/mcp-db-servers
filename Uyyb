from mcp.server.fastmcp import FastMCP
import win32com.client
import csv
import os

mcp = FastMCP("Outlook Smart MCP")

# ---------------------------
# Outlook Connection
# ---------------------------
def get_outlook():
    outlook = win32com.client.Dispatch("Outlook.Application")
    namespace = outlook.GetNamespace("MAPI")
    return outlook, namespace


# ---------------------------
# Load DB Instructions
# ---------------------------
def load_db_instructions() -> str:
    """
    Reads instructions.md for schema + query guidance
    """
    try:
        with open("instructions.md", "r", encoding="utf-8") as f:
            return f.read()
    except Exception as e:
        return f"Error reading instructions: {str(e)}"


# ---------------------------
# TOOL 1: Read Email
# ---------------------------
@mcp.tool()
def read_email_full(subject_keyword: str) -> dict:
    outlook, namespace = get_outlook()
    inbox = namespace.GetDefaultFolder(6)

    messages = inbox.Items
    messages.Sort("[ReceivedTime]", True)

    for message in messages:
        try:
            if subject_keyword.lower() in str(message.Subject).lower():
                return {
                    "subject": message.Subject,
                    "sender": message.SenderName,
                    "body": message.Body,
                    "entry_id": message.EntryID
                }
        except Exception:
            continue

    return {"error": "No matching email found"}


# ---------------------------
# TOOL 2: Intent Analyzer
# ---------------------------
@mcp.tool()
def analyze_intent(email_body: str) -> str:
    body = email_body.lower()

    if "report" in body or "data" in body:
        return "DATA_REQUEST"
    elif "invoice" in body:
        return "INVOICE_REQUEST"
    elif "export" in body or "csv" in body:
        return "EXPORT_REQUEST"
    else:
        return "GENERAL_REPLY"


# ---------------------------
# TOOL 3: Execute DB Query via MCP
# ---------------------------
@mcp.tool()
def execute_db_query(intent: str) -> list:
    """
    Uses instructions.md + intent to build query
    and calls external MCP DB tool
    """

    instructions = load_db_instructions()

    # ---------------------------
    # VERY SIMPLE RULE LOGIC (can be upgraded to LLM later)
    # ---------------------------
    if intent == "DATA_REQUEST":
        query = "SELECT name, sales FROM sales_table LIMIT 10;"
    elif intent == "INVOICE_REQUEST":
        query = "SELECT invoice_id, amount FROM invoices LIMIT 10;"
    else:
        return []

    # ---------------------------
    # CALL EXTERNAL MCP TOOL
    # ---------------------------
    try:
        # Replace 'db.run_sql' with your actual tool name
        result = mcp.call_tool("db.run_sql", {"query": query})
        return result

    except Exception as e:
        return [{"error": str(e)}]


# ---------------------------
# TOOL 4: Export CSV
# ---------------------------
@mcp.tool()
def export_to_csv(data: list, filename: str = "output.csv") -> str:
    if not data or "error" in str(data):
        return "No valid data to export"

    keys = data[0].keys()
    filepath = os.path.join(os.getcwd(), filename)

    with open(filepath, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=keys)
        writer.writeheader()
        writer.writerows(data)

    return filepath


# ---------------------------
# TOOL 5: Smart Draft Reply
# ---------------------------
@mcp.tool()
def smart_draft_reply(subject_keyword: str) -> str:

    outlook, namespace = get_outlook()

    # Step 1: Read email
    email = read_email_full(subject_keyword)
    if "error" in email:
        return email["error"]

    body = email["body"]
    entry_id = email["entry_id"]

    # Step 2: Intent
    intent = analyze_intent(body)

    response_text = ""
    attachment_path = None

    # Step 3: DB Query via MCP
    if intent in ["DATA_REQUEST", "INVOICE_REQUEST", "EXPORT_REQUEST"]:

        data = execute_db_query(intent)

        if data:
            attachment_path = export_to_csv(data)

            response_text = (
                "Hi,\n\n"
                "Please find the requested data attached.\n\n"
                "Regards,\n"
            )
        else:
            response_text = (
                "Hi,\n\n"
                "We couldn't find the requested data.\n\n"
                "Regards,\n"
            )

    else:
        response_text = (
            "Hi,\n\n"
            "Thanks for your email. We will get back to you shortly.\n\n"
            "Best regards,\n"
        )

    # Step 4: Draft reply
    try:
        mail_item = namespace.GetItemFromID(entry_id)
        reply = mail_item.Reply()

        reply.Body = response_text + "\n\n" + reply.Body

        if attachment_path and os.path.exists(attachment_path):
            reply.Attachments.Add(attachment_path)

        reply.Save()

        return f"Draft created with intent: {intent}"

    except Exception as e:
        return f"Error creating draft: {str(e)}"


# ---------------------------
# Run MCP Server
# ---------------------------
if __name__ == "__main__":
    mcp.run()
